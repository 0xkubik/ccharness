#!/usr/bin/env bash
# musician-watch — follow the live action feed of the most recent musician run in this repo.
# Run it in a separate terminal while a musician works to see, in real time, which instruments it
# calls and roughly what it is doing. Plain `tail -f` on the same file works too.
#
# Pass a run-id to watch a specific run; with no argument it picks the newest (run-ids sort
# chronologically).
set -u

RUNS=".claude/ccharness/musician/runs"
RID="${1:-}"
if [ -z "$RID" ]; then
  RID="$(ls -1 "$RUNS" 2>/dev/null | sort | tail -1)"
fi

LOG="$RUNS/$RID/live.log"
if [ -z "$RID" ] || [ ! -f "$LOG" ]; then
  echo "No musician live feed here ($RUNS/<run-id>/live.log)."
  echo "Start one with /musician, then run this again."
  exit 0
fi

echo "🎼 watching $LOG  —  Ctrl-C to stop"
exec tail -n 40 -f "$LOG"
