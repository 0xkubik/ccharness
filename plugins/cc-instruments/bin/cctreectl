#!/usr/bin/env bash
# cctreectl — print the project's folder tree, leaving out whatever .gitignore ignores.
# The cc-* script's "Map the codebase" stage uses it so the model can see the whole
# project at a glance before placing a change. It picks the richest tree tool installed
# (eza, then tree); with neither present it falls back to the git file list, which honors
# .gitignore by definition and always works inside a repo.
set -eu

usage() {
  cat <<'EOF'
cctreectl — print the project's folder tree (respecting .gitignore)

Usage: cctreectl [path]

Prints the directory tree rooted at <path> (default: the current directory),
leaving out anything .gitignore excludes — so .git, build output, node_modules
and the like stay out of the picture.

It uses whichever tool is installed, preferring the richer output:
  1. eza  --tree --git-ignore   (a tree view)
  2. tree --gitignore           (a tree view)
  3. git ls-files               (a flat file list — the fallback; always works in a repo)

Install eza or tree for the tree view — see /cc-init.
EOF
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
esac

root="${1:-.}"

if [ ! -d "$root" ]; then
  echo "cctreectl: '$root' is not a directory." >&2
  exit 1
fi

if command -v eza >/dev/null 2>&1; then
  exec eza --tree --all --git-ignore --ignore-glob='.git' "$root"
elif command -v tree >/dev/null 2>&1; then
  exec tree -a -I '.git' --gitignore "$root"
elif command -v git >/dev/null 2>&1 && git -C "$root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "(no tree tool found — showing the git file list; install eza or tree via /cc-init for a tree view)"
  git -C "$root" ls-files --cached --others --exclude-standard
else
  echo "cctreectl: no tree tool (eza or tree) found and '$root' is not a git repo — nothing to map." >&2
  echo "Install eza or tree (see /cc-init), or run inside a git repository." >&2
  exit 1
fi
