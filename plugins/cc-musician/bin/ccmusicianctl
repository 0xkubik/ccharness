#!/usr/bin/env bash
# ccmusicianctl — inspect, steer, and launch this project's musician runs from the shell.
#
# Project-local: it reads/writes .claude/ccharness/musician/ in the current repo (the machine-wide
# fleet view across all repos is `ccconductorctl`). Call it with the `!` prefix inside Claude Code, or
# straight from a terminal sitting in the repo. `musiciansctl` is a thin alias for this command.
#
# Grammar (verb-first, shared with `ccconductorctl`):
#   ccmusicianctl ls [--json]               list every run here (id, state, nonstop, age, task)
#   ccmusicianctl info <id>                 the full card for one run
#   ccmusicianctl logs <id> [--tail N]      print the tail of a run's live action feed (no follow)
#   ccmusicianctl watch [<id>]              follow a run's live feed (newest run if no id)
#   ccmusicianctl start "<task>" [--repo P] launch an autonomous musician on the repo (detached)
#   ccmusicianctl stop <id>                 soft-cancel a run (the /musician-cancel brake, by id)
#   ccmusicianctl nonstop <id> on|off       arm/disarm nonstop for that run's session
#   ccmusicianctl nonstop on|off            same, for the musician in the current session
#   ccmusicianctl prune [flags]             delete finished run folders (declutter); flags compose:
#     -n, --dry-run                           list what would go, delete nothing
#     --keep N                                keep the N newest candidates (protected before --older-than)
#     --older-than DUR                        only runs older than DUR (7d/24h/90m/30s)
#     --outcome LIST                          only these outcomes (comma-sep: cancelled,empty,achieved)
#     --orphans                               also reap crashed runs (active but heartbeat >30m stale)
#
# <id> matches a run-id exactly, or by unique prefix. `nonstop on` only sets the flag — it does NOT
# launch a musician; start one with `ccmusicianctl start` or /musician. When armed, the musician keeps
# walking the roadmap (re-launching after each piece closes) until it finds nothing left or you disarm.
#
# `prune` removes only CLOSED runs by default (active ones are left alone); `--orphans` additionally
# reaps runs that look crashed, and your own session's active run is never pruned. Preview with --dry-run.
#
# Several musicians can run on one repo at once — each builds in its own worktree and keys its state
# by session, so independent (non-colliding) tasks parallelise freely.
set -u

MUS=".claude/ccharness/musician"
RUNS="$MUS/runs"
NS=".claude/ccharness/nonstop/by-session"

now_iso() { date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "1970-01-01T00:00:00Z"; }

gen_uuid() {  # a session id for a launched musician; falls back if uuidgen is absent
  if command -v uuidgen >/dev/null 2>&1; then uuidgen | tr 'A-Z' 'a-z'
  elif [ -r /proc/sys/kernel/random/uuid ]; then cat /proc/sys/kernel/random/uuid
  else printf '%s-%04x%04x\n' "$(date -u +%Y%m%d%H%M%S 2>/dev/null || echo 00000000000000)" "$RANDOM" "$RANDOM"; fi
}

# json_field <file> <key>  ->  value of a string/scalar field (jq if present, else pure-bash regex,
# so the nonstop toggle still works with no jq on PATH). Objects/arrays are not parsed (callers that
# need to know "is this object present" use grep on the raw text instead).
json_field() {
  local file="$1" key="$2" raw
  [ -f "$file" ] || return 0
  if command -v jq >/dev/null 2>&1; then
    jq -r --arg k "$key" '.[$k] // "" | if type=="object" or type=="array" then "" else tostring end' \
       "$file" 2>/dev/null && return 0
  fi
  raw="$(<"$file")"
  local re="\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\""
  if [[ $raw =~ $re ]]; then printf '%s' "${BASH_REMATCH[1]}"; return 0; fi
  re="\"$key\"[[:space:]]*:[[:space:]]*([^,}[:space:]]+)"
  [[ $raw =~ $re ]] && printf '%s' "${BASH_REMATCH[1]}"
}

# json_escape <string>  ->  a JSON-safe inner string (for `ls --json` when jq is absent).
json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"; s="${s//\"/\\\"}"
  s="${s//$'\n'/ }"; s="${s//$'\t'/ }"
  printf '%s' "$s"
}

is_awaiting() { grep -Eq '"awaiting"[[:space:]]*:[[:space:]]*\{' "$1" 2>/dev/null; }

# resolve_id <query>  ->  the one full run-id matching exactly or by unique prefix; empty if 0 or >1.
resolve_id() {
  local q="$1" d matches=()
  [ -n "$q" ] || return 0
  [ -d "$RUNS" ] || return 0
  if [ -d "$RUNS/$q" ]; then printf '%s' "$q"; return 0; fi
  for d in "$RUNS/$q"*; do
    [ -d "$d" ] && matches+=("${d##*/}")
  done
  [ "${#matches[@]}" -eq 1 ] && printf '%s' "${matches[0]}"
}

ns_on() {  # nonstop armed for session $1 ?
  local f="$NS/$1"
  [ -f "$f" ] || return 1
  [ "$(json_field "$f" on)" = "true" ]
}

state_label() {  # short state for run dir $1
  local st="$1/state.json" active outcome
  active="$(json_field "$st" active)"
  if [ "$active" = "true" ]; then
    is_awaiting "$st" && { echo "awaiting"; return; }
    [ "$(json_field "$st" phase)" = "shaping" ] && { echo "shaping"; return; }
    echo "working"; return
  fi
  outcome="$(json_field "$st" outcome)"
  if [ -n "$outcome" ] && [ "$outcome" != "null" ]; then echo "$outcome"; else echo "closed"; fi
}

iso_to_epoch() {
  date -j -f "%Y-%m-%dT%H:%M:%SZ" "$1" +%s 2>/dev/null || date -d "$1" +%s 2>/dev/null || echo ""
}

parse_dur() {  # "7d"/"24h"/"90m"/"30s" -> seconds; empty on a malformed value
  local s="$1"
  [[ "$s" =~ ^([0-9]+)([smhd])$ ]] || { echo ""; return; }
  local n="${BASH_REMATCH[1]}"
  case "${BASH_REMATCH[2]}" in
    s) echo "$n" ;;
    m) echo "$((n*60))" ;;
    h) echo "$((n*3600))" ;;
    d) echo "$((n*86400))" ;;
  esac
}

human_age() {  # seconds -> "5s"/"4m"/"2h"/"3d"
  local s="$1"
  [ -n "$s" ] || { echo "—"; return; }
  if   [ "$s" -lt 60 ];    then echo "${s}s"
  elif [ "$s" -lt 3600 ];  then echo "$((s/60))m"
  elif [ "$s" -lt 86400 ]; then echo "$((s/3600))h"
  else echo "$((s/86400))d"; fi
}

run_age() {  # run dir $1 -> human age since started_at
  local started ep now
  started="$(json_field "$1/state.json" started_at)"
  ep="$(iso_to_epoch "$started")"
  [ -n "$ep" ] || { echo "—"; return; }
  now="$(date +%s 2>/dev/null || echo 0)"
  human_age "$((now - ep))"
}

run_input() {  # run dir $1 -> the full task text, or "(open)"
  local input; input="$(json_field "$1/state.json" input)"
  [ -n "$input" ] && printf '%s' "$input" || printf '(open)'
}

run_task() {  # run dir $1 -> task text (truncated for the table) or "(open)"
  local input; input="$(run_input "$1")"
  [ "${#input}" -gt 50 ] && input="${input:0:49}…"
  echo "$input"
}

task_progress() {  # run dir $1 -> "N/M" completed/total tasks, or "" (no tasks, or no jq)
  local st="$1/state.json" done total
  command -v jq >/dev/null 2>&1 || { echo ""; return; }
  done="$(jq -r '[(.tasks // [])[] | select(.status=="completed")] | length' "$st" 2>/dev/null)"
  total="$(jq -r '(.tasks // []) | length' "$st" 2>/dev/null)"
  { [ -n "$total" ] && [ "$total" -gt 0 ] 2>/dev/null; } && echo "$done/$total" || echo ""
}

do_ls() {  # do_ls [--json]
  local as_json=false
  [ "${1:-}" = "--json" ] && as_json=true
  if [ ! -d "$RUNS" ] || [ -z "$(ls -A "$RUNS" 2>/dev/null)" ]; then
    [ "$as_json" = true ] && { echo "[]"; return 0; }
    echo "No musician runs in this repo yet. Start one with: ccmusicianctl start \"<task>\""
    return 0
  fi
  local d id sid ns
  if [ "$as_json" = true ]; then
    local first=true
    printf '['
    while IFS= read -r id; do
      d="$RUNS/$id"
      [ -f "$d/state.json" ] || continue
      sid="$(json_field "$d/state.json" session_id)"
      if [ -n "$sid" ] && ns_on "$sid"; then ns="on"; else ns="off"; fi
      [ "$first" = true ] && first=false || printf ','
      printf '{"id":"%s","state":"%s","nonstop":"%s","age":"%s","tasks":"%s","task":"%s","session":"%s"}' \
        "$(json_escape "$id")" "$(json_escape "$(state_label "$d")")" "$ns" \
        "$(json_escape "$(run_age "$d")")" "$(task_progress "$d")" "$(json_escape "$(run_input "$d")")" "$(json_escape "$sid")"
    done < <(ls -1 "$RUNS" 2>/dev/null | sort -r)
    printf ']\n'
    return 0
  fi
  printf '%-22s %-9s %-8s %-5s %-6s %s\n' "ID" "STATE" "NONSTOP" "AGE" "TASKS" "TASK"
  while IFS= read -r id; do
    d="$RUNS/$id"
    [ -f "$d/state.json" ] || continue
    sid="$(json_field "$d/state.json" session_id)"
    if [ -n "$sid" ] && ns_on "$sid"; then ns="on"; else ns="off"; fi
    printf '%-22s %-9s %-8s %-5s %-6s %s\n' \
      "$id" "$(state_label "$d")" "$ns" "$(run_age "$d")" "$(task_progress "$d")" "$(run_task "$d")"
  done < <(ls -1 "$RUNS" 2>/dev/null | sort -r)
}

do_info() {  # do_info <id>
  local rid; rid="$(resolve_id "${1:-}")"
  [ -n "$rid" ] || { echo "ccmusicianctl: no run matches '${1:-}' (try: ccmusicianctl ls)" >&2; exit 2; }
  local d="$RUNS/$rid" st="$RUNS/$rid/state.json" sid ns
  sid="$(json_field "$st" session_id)"
  if [ -n "$sid" ] && ns_on "$sid"; then ns="on"; else ns="off"; fi
  printf '%-12s %s\n' "id"        "$rid"
  printf '%-12s %s\n' "mode"      "$(json_field "$st" entry)"
  printf '%-12s %s\n' "task"      "$(run_input "$d")"
  printf '%-12s %s\n' "state"     "$(state_label "$d")"
  printf '%-12s %s\n' "nonstop"   "$ns"
  printf '%-12s %s\n' "started"   "$(json_field "$st" started_at)"
  printf '%-12s %s\n' "tasks"     "$(task_progress "$d")"
  printf '%-12s %s\n' "session"   "$sid"
  printf '%-12s %s\n' "dir"       "$d"
}

do_logs() {  # do_logs <id> [--tail N] -> print the tail of a run's live feed (no follow)
  local id="" n=40
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --tail) shift; n="${1:-40}" ;;
      *)      [ -z "$id" ] && id="$1" ;;
    esac
    shift
  done
  local rid; rid="$(resolve_id "$id")"
  [ -n "$rid" ] || { echo "ccmusicianctl: no run matches '$id' (try: ccmusicianctl ls)" >&2; exit 2; }
  local log="$RUNS/$rid/live.log"
  [ -f "$log" ] || { echo "No live feed yet for $rid ($log)."; return 0; }
  tail -n "$n" "$log"
}

do_watch() {  # do_watch <id-or-empty> -> follow a run's live feed (newest run if empty)
  local rid="$1" log
  if [ -z "$rid" ]; then
    rid="$(ls -1 "$RUNS" 2>/dev/null | sort | tail -1)"
  else
    rid="$(resolve_id "$rid")"
  fi
  log="$RUNS/$rid/live.log"
  if [ -z "$rid" ] || [ ! -f "$log" ]; then
    echo "No musician live feed here ($RUNS/<run-id>/live.log)."
    echo "Start one with: ccmusicianctl start \"<task>\", then run this again."
    exit 0
  fi
  echo "🎼 watching $log  —  Ctrl-C to stop"
  exec tail -n 40 -f "$log"
}

do_start() {  # do_start "<task>" [--repo P] -> launch an autonomous musician, detached
  local repo="" task=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo) shift; repo="${1:-}" ;;
      *)      task="${task:+$task }$1" ;;
    esac
    shift
  done
  [ -n "$task" ] || { echo "ccmusicianctl: start needs a task — ccmusicianctl start \"<what to build>\"" >&2; exit 2; }
  repo="${repo:-$PWD}"
  [ -d "$repo" ] || { echo "ccmusicianctl: --repo path not found: $repo" >&2; exit 2; }
  local sid launcher sdir
  sid="$(gen_uuid)"
  # CCMUSICIAN_CLAUDE overrides the launched binary (used by tests and to wrap claude).
  launcher="${CCMUSICIAN_CLAUDE:-claude}"
  sdir="$repo/.claude/ccharness/musician/spawn"
  mkdir -p "$sdir" 2>/dev/null || true
  # Detached + fully autonomous: --auto skips the collaborative shaping phase (nobody's here to
  # answer), and bypassPermissions lets the background musician run builds/tests/git unattended.
  local -a argv=("$launcher" -p "/musician --auto $task"
                 --session-id "$sid" --permission-mode bypassPermissions)
  printf '%s\n' "${argv[*]}" > "$sdir/$sid.cmd"
  ( cd "$repo" && nohup "${argv[@]}" >> "$sdir/$sid.log" 2>&1 & )
  echo "🎼 launching musician on $repo"
  echo "   session ${sid:0:8} — follow with: ccmusicianctl watch   (list: ccmusicianctl ls)"
}

do_stop() {  # do_stop <id> -> soft cancel: flip the run closed + drop its session pointer
  local id="${1:-}"
  local rid; rid="$(resolve_id "$id")"
  [ -n "$rid" ] || { echo "ccmusicianctl: no run matches '$id' (try: ccmusicianctl ls)" >&2; exit 2; }
  local st="$RUNS/$rid/state.json" sid prog
  sid="$(json_field "$st" session_id)"
  prog="$(task_progress "$RUNS/$rid")"
  # Flip the run closed (the durable record). The pointer removal below is the actual brake and
  # always runs, so a jq-less box still stops the loop — it just won't record the cancellation.
  if command -v jq >/dev/null 2>&1 && [ -f "$st" ]; then
    local tmp="$st.tmp.$$"
    jq '.active=false | .status="cancelled" | .outcome="cancelled"' "$st" > "$tmp" 2>/dev/null && mv "$tmp" "$st"
  fi
  # Drop the session pointer -> the musician Stop hook releases AND nonstop no-ops (no run dir).
  [ -n "$sid" ] && rm -f "$MUS/by-session/$sid"
  echo "⏹  musician $rid cancelled — the loop releases at its next stop${prog:+ (tasks: $prog)}."
}

do_nonstop() {  # do_nonstop <id-or-empty> <on|off>
  local id="$1" action="${2:-}" sid=""
  if [ -z "$id" ]; then
    sid="${CLAUDE_CODE_SESSION_ID:-}"
    if [ -z "$sid" ]; then
      echo "ccmusicianctl: no CLAUDE_CODE_SESSION_ID in this shell — name the run instead:" >&2
      echo "  ccmusicianctl nonstop <id> ${action:-on|off}   (find the id with: ccmusicianctl ls)" >&2
      exit 2
    fi
  else
    local rid; rid="$(resolve_id "$id")"
    [ -n "$rid" ] || { echo "ccmusicianctl: no run matches '$id' (try: ccmusicianctl ls)" >&2; exit 2; }
    sid="$(json_field "$RUNS/$rid/state.json" session_id)"
    [ -n "$sid" ] || { echo "ccmusicianctl: run '$rid' records no session — cannot toggle nonstop" >&2; exit 2; }
  fi
  mkdir -p "$NS" 2>/dev/null || true
  local f="$NS/$sid"
  case "$action" in
    on)
      local tmp="$f.tmp.$$"
      printf '{"on":true,"session_id":"%s","armed_at":"%s"}\n' "$sid" "$(now_iso)" > "$tmp" && mv "$tmp" "$f"
      echo "🔁 nonstop ON for session ${sid:0:8} — after each piece closes the musician picks the next"
      echo "   roadmap milestone and keeps going. It does NOT launch one now; start with ccmusicianctl start."
      ;;
    off)
      rm -f "$f"
      echo "⏹  nonstop OFF for session ${sid:0:8} — a piece mid-run finishes, then the musician stops."
      ;;
    *)
      echo "ccmusicianctl: nonstop needs 'on' or 'off'" >&2; exit 2 ;;
  esac
}

do_prune() {  # delete finished run folders; see the header for the flag grammar
  local dry=false keep="" older="" outcome_csv="" orphans=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -n|--dry-run) dry=true ;;
      --keep)       shift; keep="${1:-}" ;;
      --older-than) shift; older="${1:-}" ;;
      --outcome)    shift; outcome_csv="${1:-}" ;;
      --orphans)    orphans=true ;;
      *) echo "ccmusicianctl: prune: unknown flag '$1' — see: ccmusicianctl --help" >&2; exit 2 ;;
    esac
    shift
  done
  if [ -n "$keep" ] && ! [[ "$keep" =~ ^[0-9]+$ ]]; then
    echo "ccmusicianctl: prune --keep needs a number (got '$keep')" >&2; exit 2
  fi
  local older_s=""
  if [ -n "$older" ]; then
    older_s="$(parse_dur "$older")"
    [ -n "$older_s" ] || { echo "ccmusicianctl: prune --older-than needs a duration like 7d/24h/90m/30s (got '$older')" >&2; exit 2; }
  fi
  if [ ! -d "$RUNS" ] || [ -z "$(ls -A "$RUNS" 2>/dev/null)" ]; then
    echo "No musician runs in this repo — nothing to prune."; return 0
  fi

  local now cur_run="" cursid
  now="$(date +%s 2>/dev/null || echo 0)"
  cursid="${CLAUDE_CODE_SESSION_ID:-}"
  # Never prune the run owned by THIS session — not even as an orphan.
  [ -n "$cursid" ] && [ -f "$MUS/by-session/$cursid" ] && cur_run="$(cat "$MUS/by-session/$cursid" 2>/dev/null)"

  # --- collect candidates: closed runs always; active runs only with --orphans and a dead heartbeat.
  #     Each entry is "epoch<TAB>id" so we can sort newest-first for --keep. ---
  local -a cand=()
  local d id st active oc hb hbe ep
  for d in "$RUNS"/*; do
    [ -d "$d" ] || continue
    id="${d##*/}"; st="$d/state.json"
    [ -f "$st" ] || continue
    [ "$id" = "$cur_run" ] && continue
    active="$(json_field "$st" active)"
    if [ "$active" = "true" ]; then
      [ "$orphans" = true ] || continue
      hb="$d/heartbeat"; [ -f "$hb" ] || continue
      hbe="$(stat -f %m "$hb" 2>/dev/null || stat -c %Y "$hb" 2>/dev/null || echo "")"
      [ -n "$hbe" ] || continue
      [ "$(( (now - hbe) / 60 ))" -ge 30 ] || continue
    fi
    if [ -n "$outcome_csv" ]; then
      oc="$(json_field "$st" outcome)"
      case ",$outcome_csv," in *,"$oc",*) : ;; *) continue ;; esac
    fi
    ep="$(iso_to_epoch "$(json_field "$st" started_at)")"; [ -n "$ep" ] || ep=0
    cand+=("$ep	$id")
  done
  [ "${#cand[@]}" -gt 0 ] || { echo "Nothing to prune."; return 0; }

  # --- sort newest-first, then apply the two orthogonal protections and delete ---
  local -a sorted=()
  local line
  while IFS= read -r line; do sorted+=("$line"); done < <(printf '%s\n' "${cand[@]}" | sort -t$'\t' -k1,1nr)

  local rank=0 pruned=0 sid
  for line in "${sorted[@]}"; do
    ep="${line%%$'\t'*}"; id="${line#*$'\t'}"; d="$RUNS/$id"
    if [ -n "$keep" ] && [ "$rank" -lt "$keep" ]; then rank=$((rank+1)); continue; fi
    rank=$((rank+1))
    if [ -n "$older_s" ]; then
      [ "$ep" -gt 0 ] 2>/dev/null || continue          # unknown age -> never age-prune
      [ "$(( now - ep ))" -ge "$older_s" ] || continue
    fi
    if [ "$dry" = true ]; then
      echo "[dry-run] would prune $id ($(state_label "$d"), $(run_age "$d"))"
    else
      sid="$(json_field "$d/state.json" session_id)"
      rm -rf "$d"
      # drop a now-dangling session pointer that named this run
      [ -n "$sid" ] && [ -f "$MUS/by-session/$sid" ] && \
        [ "$(cat "$MUS/by-session/$sid" 2>/dev/null)" = "$id" ] && rm -f "$MUS/by-session/$sid"
      echo "pruned $id"
    fi
    pruned=$((pruned+1))
  done

  if [ "$pruned" -eq 0 ]; then echo "Nothing to prune."
  elif [ "$dry" = true ]; then echo "[dry-run] $pruned run(s) would be pruned; nothing deleted."
  else echo "Pruned $pruned run(s)."; fi
}

usage() {
  sed -n '2,/^set -u/{/^set -u/d;p;}' "$0" | sed 's/^# \{0,1\}//'
}

cmd="${1:-}"; [ "$#" -gt 0 ] && shift
case "$cmd" in
  ""|ls)     do_ls "$@" ;;
  -h|--help) usage ;;
  info)      do_info "${1:-}" ;;
  logs)      do_logs "$@" ;;
  watch)     do_watch "${1:-}" ;;
  start)     do_start "$@" ;;
  stop)      do_stop "${1:-}" ;;
  prune)     do_prune "$@" ;;
  nonstop)
    if [ "${1:-}" = "on" ] || [ "${1:-}" = "off" ]; then
      do_nonstop "" "${1:-}"
    else
      do_nonstop "${1:-}" "${2:-}"
    fi
    ;;
  *)
    echo "ccmusicianctl: unknown command '$cmd' — see: ccmusicianctl --help" >&2; exit 2 ;;
esac
