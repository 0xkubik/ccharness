#!/usr/bin/env bash
# ccscriptctl — small terminal helpers for the cc-script harness.
# It opens the project's roadmap or cheat-sheet in your editor, and captures quick
# roadmap notes from the shell, so you don't have to dig into .claude/ccharness/ by
# hand. More helpers may be added over time.
set -eu

usage() {
  cat <<'EOF'
ccscriptctl — small helpers for the cc-script harness

Usage: ccscriptctl <command>

Commands:
  roadmap open              Open .claude/ccharness/roadmap.md in your editor
  roadmap add <kind> <text> Append a note to roadmap.md without opening it,
                            where <kind> is one of:
                              feat      → the "## Features" section (the route)
                              todo      → the "## TODO" section
                              backlog   → the "## Backlog" section
                              bug       → the "## Bugs" section
                            Missing sections are created in that order.
  cheatsheet                Open .claude/ccharness/cheatsheet.md in your editor
  help                      Show this help

Files open in your OS default app (open / xdg-open) and the command returns at
once; with no opener it falls back to $VISUAL / $EDITOR. ccscriptctl finds
.claude/ccharness/ in the current directory or any parent, so it works from
anywhere inside a project.
EOF
}

# Walk up from the current directory to the nearest ancestor holding .claude/ccharness/.
find_ccharness() {
  local dir="$PWD"
  while :; do
    if [ -d "$dir/.claude/ccharness" ]; then
      printf '%s\n' "$dir/.claude/ccharness"
      return 0
    fi
    [ "$dir" = "/" ] && return 1
    dir="$(dirname "$dir")"
  done
}

# Print the ccharness dir, or exit 1 with a hint to run the owning skill.
require_ccharness() {
  local skill="$1" dir
  if ! dir="$(find_ccharness)"; then
    echo "ccscriptctl: no .claude/ccharness/ found in '$PWD' or any parent." >&2
    echo "Run $skill in your project to create it." >&2
    exit 1
  fi
  printf '%s\n' "$dir"
}

# Exit 1 with a hint if the target file does not exist yet.
require_file() {
  local file="$1" skill="$2"
  if [ ! -f "$file" ]; then
    echo "ccscriptctl: $file does not exist yet." >&2
    echo "Run $skill to create it." >&2
    exit 1
  fi
}

# "Open it and get out of the way." Prefer the desktop opener (open / xdg-open) —
# it hands the file to the default app and returns at once, so ccscriptctl never
# blocks. $VISUAL/$EDITOR are the headless/terminal fallback, launched detached so
# a waiting editor (e.g. `code --wait`) can't hang the command either.
open_in_editor() {
  local file="$1"
  if command -v open >/dev/null 2>&1; then
    exec open "$file"
  elif command -v xdg-open >/dev/null 2>&1; then
    exec xdg-open "$file"
  elif [ -n "${VISUAL:-}" ]; then
    nohup ${VISUAL} "$file" >/dev/null 2>&1 &
  elif [ -n "${EDITOR:-}" ]; then
    nohup ${EDITOR} "$file" >/dev/null 2>&1 &
  else
    echo "ccscriptctl: no way to open '$file' — install a desktop opener (open / xdg-open) or set \$EDITOR/\$VISUAL." >&2
    exit 1
  fi
}

# The roadmap's sections keep a fixed order; a missing one is created in its slot.
# Print the sections that should sit after the given one (its ordered successors).
section_successors() {
  case "$1" in
    Features) printf '%s\n' TODO Backlog Bugs ;;
    TODO)     printf '%s\n' Backlog Bugs ;;
    Backlog)  printf '%s\n' Bugs ;;
    Bugs)     : ;;
  esac
}

# Append "- [ ] <text>" under "## <section>" in the roadmap. If the section isn't
# there yet, create it in its canonical slot (Features → TODO → Backlog → Bugs):
# just before the first later section that already exists, else at the end of the
# file. The "## Features" route is shared with roadmap-management.
roadmap_add_note() {
  local section="$1" bullet="$2" file="$3" heading tmp successor cand
  heading="## $section"
  if grep -qxF "$heading" "$file"; then
    tmp="$(mktemp)"
    BULLET="$bullet" awk -v heading="$heading" '
      function flush() {
        while (n > 0 && buf[n] ~ /^[[:space:]]*$/) n--
        for (i = 1; i <= n; i++) print buf[i]
        print ENVIRON["BULLET"]
        n = 0; in_sec = 0
      }
      BEGIN { in_sec = 0; n = 0 }
      {
        if (!in_sec && $0 == heading) { print; in_sec = 1; next }
        if (in_sec) {
          if (/^## /) { flush(); print ""; print; next }
          buf[++n] = $0; next
        }
        print
      }
      END { if (in_sec) flush() }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
    return
  fi

  successor=""
  for cand in $(section_successors "$section"); do
    if grep -qxF "## $cand" "$file"; then successor="## $cand"; break; fi
  done

  if [ -n "$successor" ]; then
    tmp="$(mktemp)"
    BULLET="$bullet" awk -v succ="$successor" -v heading="$heading" '
      $0 == succ && !done { print heading; print ""; print ENVIRON["BULLET"]; print ""; done = 1 }
      { print }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
  else
    [ -n "$(tail -c1 "$file")" ] && printf '\n' >> "$file"
    printf '\n%s\n\n%s\n' "$heading" "$bullet" >> "$file"
  fi
}

cmd_roadmap() {
  local sub="${1:-}"
  case "$sub" in
    open)
      local ccdir file
      ccdir="$(require_ccharness /roadmap-management)"
      file="$ccdir/roadmap.md"
      require_file "$file" /roadmap-management
      open_in_editor "$file"
      ;;
    add)
      shift || true
      local kind section
      kind="${1:-}"
      case "$kind" in
        feat)    section="Features" ;;
        todo)    section="TODO" ;;
        backlog) section="Backlog" ;;
        bug)     section="Bugs" ;;
        "")      echo "ccscriptctl: 'roadmap add' needs a kind (feat|todo|backlog|bug) and text." >&2; exit 2 ;;
        *)       echo "ccscriptctl: unknown kind '$kind' — use feat, todo, backlog, or bug." >&2; exit 2 ;;
      esac
      shift || true
      local text="$*"
      if [ -z "$text" ]; then
        echo "ccscriptctl: 'roadmap add $kind' needs some text to record." >&2
        exit 2
      fi
      local ccdir file
      ccdir="$(require_ccharness /roadmap-management)"
      file="$ccdir/roadmap.md"
      require_file "$file" /roadmap-management
      roadmap_add_note "$section" "- [ ] $text" "$file"
      echo "Added to $section in $file:"
      echo "  - [ ] $text"
      ;;
    "")
      echo "ccscriptctl: 'roadmap' needs a subcommand — 'open' or 'add'." >&2
      echo >&2
      usage >&2
      exit 2
      ;;
    *)
      echo "ccscriptctl: unknown roadmap subcommand '$sub'." >&2
      echo >&2
      usage >&2
      exit 2
      ;;
  esac
}

case "${1:-help}" in
  roadmap)
    shift
    cmd_roadmap "$@"
    ;;
  cheatsheet)
    ccdir="$(require_ccharness /cheatsheet-management)"
    file="$ccdir/cheatsheet.md"
    require_file "$file" /cheatsheet-management
    open_in_editor "$file"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "ccscriptctl: unknown command '$1'" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
